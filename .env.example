# Flask application entry point (used by `flask` CLI and Flask-Migrate)
FLASK_APP=socialposter.web.app:create_app

# Secret key for Flask session signing (CHANGE IN PRODUCTION)
SOCIALPOSTER_SECRET_KEY=change-me-to-a-random-secret

# Fernet encryption key for OAuth tokens stored in the DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank in development to store tokens in plaintext.
SOCIALPOSTER_ENCRYPTION_KEY=
